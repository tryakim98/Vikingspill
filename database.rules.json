{


  "rules": {
    ".read": false,
    ".write": false,

    "games": {
      ".read": false,
      ".write": false,

      
      "$code": {
        ".read": "$code.matches(/^[A-HJ-NP-Z]{4}$/) || $code.matches(/^VIKING-[A-Z0-9]{3,12}$/)",
        ".write": "$code.matches(/^[A-HJ-NP-Z]{4}$/) || $code.matches(/^VIKING-[A-Z0-9]{3,12}$/)",

        "meta": {
          "createdAt":    { ".validate": "newData.isNumber()" },
          "lastActiveAt": { ".validate": "newData.isNumber()" },
          "$other": { ".validate": false }
        },

        "settings": {
          "requireSaga":        { ".validate": "newData.isBoolean()" },
          "requirePerspective": { ".validate": "newData.isBoolean()" },
          "requireBridge":      { ".validate": "newData.isBoolean()" },
          "requireQuiz":        { ".validate": "newData.isBoolean()" },
          "requireCouncil":     { ".validate": "newData.isBoolean()" },
          "textLength":         { ".validate": "newData.isString() && newData.val().matches(/^(full|short|group)$/)" },
          "showHints":          { ".validate": "newData.isBoolean()" },
          "$other":             { ".validate": false }
        },

        "groups": {
          "$groupId": {
            "shipName":   { ".validate": "newData.isString() && newData.val().length <= 60" },
            "shipSymbol": { ".validate": "newData.isString() && newData.val().length <= 24" },
            "shipColor":  { ".validate": "newData.isString() && newData.val().length <= 24" },
            "startSkill": { ".validate": "newData.isString() && newData.val().length <= 24" },
            "scores": {
              "culturalUnderstanding": { ".validate": "newData.isNumber()" },
              "tradeGain":             { ".validate": "newData.isNumber()" },
              "reputation":            { ".validate": "newData.isNumber()" },
              "$other": { ".validate": false }
            },
            "skills":  { "$skill": { ".validate": "newData.isNumber()" } },
            "visited":       { "$i": { ".validate": "newData.isString() && newData.val().length <= 40" } },
            "locked":        { "$i": { ".validate": "newData.isString() && newData.val().length <= 40" } },
            "unlockedSides":    { "$i": { ".validate": "newData.isString() && newData.val().length <= 40" } },
            "performedActions": { "$i": { ".validate": "newData.isString() && newData.val().length <= 60" } },
            "saga": {
              "$i": {
                ".validate": "newData.hasChildren(['destId','choiceId'])",
                "$f": { ".validate": "!newData.isString() || newData.val().length <= 1000" }
              }
            },
            "textLength": { ".validate": "newData.isString() && newData.val().matches(/^(full|short)$/)" },
            "goods": {
              "$good": {
                ".validate": "$good.matches(/^(pelsverk|solv|jern|rav|silke|hvalrosstann|krydder|salt)$/) && newData.isNumber()"
              }
            },
            "updatedAt":      { ".validate": "newData.isNumber()" },
            "chiefId":        { ".validate": "newData.isString() && newData.val().matches(/^m-[a-z0-9]{1,16}$/) && newData.parent().child('members').child(newData.val()).exists()" },
            "activeDestId":   { ".validate": "newData.isString() && newData.val().length <= 40" },
            "activeSkillKey": { ".validate": "newData.isString() && newData.val().length <= 24" },
            "showCeremony":   { ".validate": "newData.isBoolean()" },
            "previewDestId":  { ".validate": "newData.isString() && newData.val().length <= 40" },
            "sailingTo":      { ".validate": "newData.isString() && newData.val().length <= 40" },
            "lastSkjebneAtVisited":  { ".validate": "newData.isNumber()" },
            "forceSkjebneNextSail": { ".validate": "newData.isBoolean()" },
            "seenHints":     { "$i": { ".validate": "newData.isString() && newData.val().length <= 40" } },
            "seenSkjebne":   { "$i": { ".validate": "newData.isString() && newData.val().length <= 40" } },
            "activeSkjebne": {
              ".validate": "newData.hasChildren(['id','pendingDestId'])",
              "id":            { ".validate": "newData.isString() && newData.val().length <= 40" },
              "pendingDestId": { ".validate": "newData.isString() && newData.val().length <= 40" },
              "choiceId":      { ".validate": "newData.isString() && newData.val().length <= 40" },
              "rollResult": {
                "roll":     { ".validate": "newData.isNumber()" },
                "bonus":    { ".validate": "newData.isNumber()" },
                "total":    { ".validate": "newData.isNumber()" },
                "won":      { ".validate": "newData.isBoolean()" },
                "$other":   { ".validate": false }
              },
              "$other": { ".validate": false }
            },
            "members": {
              "$memberId": {
                ".validate": "$memberId.matches(/^m-[a-z0-9]{1,16}$/)",
                "joinedAt":   { ".validate": "newData.isNumber()" },
                "$other":     { ".validate": false }
              }
            },
            "encounter": {
              ".validate": "newData.hasChildren(['destId','step'])",
              "destId":       { ".validate": "newData.isString() && newData.val().length <= 40" },
              "step":         { ".validate": "newData.isString() && newData.val().matches(/^(history|kulturmote|oppgave|transition|quiz|perspektiv|radslagning|valg|saga|roll|rolling|resultat|refleksjon)$/)" },
              "approvalSent": { ".validate": "newData.isBoolean()" },
              "kmAnswer":     { ".validate": "newData.isNumber()" },
              "quizIdx":      { ".validate": "newData.isNumber()" },
              "quizCorrect":  { ".validate": "newData.isNumber()" },
              "quizAnswer":   { ".validate": "newData.isNumber()" },
              "quizBonus":    { ".validate": "newData.isNumber()" },
              "choiceId":     { ".validate": "newData.isString() && newData.val().length <= 40" },
              "reason":       { ".validate": "newData.isString() && newData.val().length <= 600" },
              "hiddenAnswered":  { ".validate": "newData.isBoolean()" },
              "hiddenCorrect":   { ".validate": "newData.isBoolean()" },
              "hiddenAnswerIdx": { ".validate": "newData.isNumber()" },
              "vikingPerspective": { ".validate": "newData.isString() && newData.val().length <= 600" },
              "otherPerspective":  { ".validate": "newData.isString() && newData.val().length <= 600" },
              "bridgeReflection":  { ".validate": "newData.isString() && newData.val().length <= 600" },
              "roll": {
                "raw":       { ".validate": "newData.isNumber()" },
                "effective": { ".validate": "newData.isNumber()" },
                "modifier":  { ".validate": "newData.isNumber()" },
                "tier":      { ".validate": "newData.isString() && newData.val().matches(/^(bad|mid|good|crit)$/)" },
                "$other":    { ".validate": false }
              },
              "advice": {
                "$memberId": {
                  ".validate": "$memberId.matches(/^m-[a-z0-9]{1,16}$/)",
                  "choiceId": { ".validate": "newData.isString() && newData.val().length <= 40" },
                  "note":     { ".validate": "newData.isString() && newData.val().length <= 120" },
                  "at":       { ".validate": "newData.isNumber()" },
                  "$other":   { ".validate": false }
                }
              },
              "$other": { ".validate": false }
            },
            "lastTingAt": { ".validate": "newData.isNumber()" },
            "ting": {
              ".validate": "newData.hasChildren(['id','candidateId','incumbentId','status'])",
              "id":          { ".validate": "newData.isString() && newData.val().length <= 60" },
              "calledBy":    { ".validate": "newData.isString() && newData.val().matches(/^m-[a-z0-9]{1,16}$/)" },
              "candidateId": { ".validate": "newData.isString() && newData.val().matches(/^m-[a-z0-9]{1,16}$/)" },
              "incumbentId": { ".validate": "newData.isString() && newData.val().matches(/^m-[a-z0-9]{1,16}$/)" },
              "startedAt":   { ".validate": "newData.isNumber()" },
              "status":      { ".validate": "newData.isString() && newData.val().matches(/^(open|resolved)$/)" },
              "resultChiefId": { ".validate": "newData.isString() && newData.val().matches(/^m-[a-z0-9]{1,16}$/)" },
              "resolvedAt":  { ".validate": "newData.isNumber()" },
              "votes": {
                "$memberId": {
                  ".validate": "$memberId.matches(/^m-[a-z0-9]{1,16}$/) && newData.isString() && newData.val().matches(/^m-[a-z0-9]{1,16}$/)"
                }
              },
              "$other": { ".validate": false }
            },
            "$other": { ".validate": false }
          }
        },

        "approvals": {
          "$groupId": {
            "destId":      { ".validate": "newData.isString() && newData.val().length <= 40" },
            "taskTitle":   { ".validate": "newData.isString() && newData.val().length <= 200" },
            "shipName":    { ".validate": "newData.isString() && newData.val().length <= 60" },
            "status":      { ".validate": "newData.isString() && newData.val().length <= 20" },
            "requestedAt": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },

        "trial":       { ".validate": "newData.hasChildren(['id'])",                    "$f": { ".validate": "!newData.isString() || newData.val().length <= 1000" } },
        "trialResult": { ".validate": "newData.hasChildren(['trialId','winnerId'])",    "$f": { ".validate": "!newData.isString() || newData.val().length <= 1000" } },
        "fate":      { ".validate": "newData.hasChildren(['id'])",          "$f": { ".validate": "!newData.isString() || newData.val().length <= 1000" } },
        "wheelSpin": { ".validate": "newData.hasChildren(['id'])",          "$f": { ".validate": "!newData.isString() || newData.val().length <= 1000" } },
        "ragnarok":  { ".validate": "newData.hasChildren(['id'])",          "$f": { ".validate": "!newData.isString() || newData.val().length <= 1000" } },

        "duels": {
          "$duelId": {
            ".validate": "newData.hasChildren(['id'])",
            "$f": { ".validate": "!newData.isString() || newData.val().length <= 1000" }
          }
        },

        "trades": {
          "$tradeId": {
            ".validate": "newData.hasChildren(['id','fromGroupId','toGroupId','status'])",
            "$f": { ".validate": "!newData.isString() || newData.val().length <= 1000" }
          }
        },

        "$other": { ".validate": false }
      }
    }
  }
}
