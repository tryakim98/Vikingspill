# Mal for Firebase-konfigurasjon. Kopier denne til «.env» og fyll inn dine egne
# verdier fra Firebase-konsollen (Prosjektinnstillinger → Dine apper → web-app).
# .env er gitignorert og lastes ALDRI opp til GitHub. Denne malen (.env.example) er trygg å dele.
VITE_FIREBASE_API_KEY=LIM_INN_DIN_apiKey
VITE_FIREBASE_AUTH_DOMAIN=LIM_INN_DIN_authDomain
VITE_FIREBASE_DATABASE_URL=LIM_INN_DIN_databaseURL
VITE_FIREBASE_PROJECT_ID=LIM_INN_DIN_projectId
VITE_FIREBASE_STORAGE_BUCKET=LIM_INN_DIN_storageBucket
VITE_FIREBASE_MESSAGING_SENDER_ID=LIM_INN_DIN_messagingSenderId
VITE_FIREBASE_APP_ID=LIM_INN_DIN_appId
