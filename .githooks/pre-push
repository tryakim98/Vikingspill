#!/bin/sh
#
# Pre-push-sjekk: kjør hele prosjekt-builden (tsc -b && vite build) før push.
#
# Bakgrunn: Vercel deployer med `npm run build`. En type-feil i `tsc -b` stopper
# hele builden stille, og siden fryser på siste vellykkede deploy. Denne hooken
# fanger det lokalt så vi aldri pusher en commit som ikke kan deployes.
#
# Hopp over enkeltvis ved behov:  git push --no-verify

printf '\n\033[1;33m⚓ Pre-push: kjører «npm run build» …\033[0m\n'

if npm run build; then
  printf '\033[1;32m✓ Build OK — pusher.\033[0m\n\n'
  exit 0
else
  printf '\n\033[1;31m✗ Build feilet — push avbrutt.\033[0m\n'
  printf 'Rett feilene over, ellers ville Vercel-deployen blitt frosset.\n'
  printf 'For å pushe likevel (ikke anbefalt): git push --no-verify\n\n'
  exit 1
fi
